Options -MultiViews
RewriteEngine On

# Pass Authorization header through to PHP (Apache strips it by default)
RewriteCond %{HTTP:Authorization} .
RewriteRule ^ - [E=HTTP_AUTHORIZATION:%{HTTP:Authorization}]

SetEnvIf Authorization "(.*)" HTTP_AUTHORIZATION=$1

# Disable PHP's implicit output buffering and gzip compression: with either
# one on, the SSE stream (/sla/stream) gets fully buffered and only flushes
# to the browser when the connection closes, defeating the whole point of
# real-time push. Harmless for the normal JSON endpoints (they just print
# once and exit).
<IfModule mod_php.c>
    php_value output_buffering "0"
    php_flag  zlib.output_compression Off
</IfModule>
<IfModule mod_deflate.c>
    SetEnvIfNoCase Request_URI "sla/stream" no-gzip
</IfModule>

# Handle CORS preflight before PHP runs
<IfModule mod_headers.c>
    Header always set Access-Control-Allow-Origin "*"
    Header always set Access-Control-Allow-Methods "GET, POST, PUT, DELETE, OPTIONS"
    Header always set Access-Control-Allow-Headers "Content-Type, Authorization"
</IfModule>

# Return 200 for OPTIONS without going to PHP
RewriteCond %{REQUEST_METHOD} OPTIONS
RewriteRule ^ - [R=200,L]

# Route everything else through index.php
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^ index.php [QSA,L]
